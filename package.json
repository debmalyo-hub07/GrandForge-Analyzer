{
  "name": "grandforge",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "GrandForge — Forge Your Game. Master the Board. Production-grade chess analysis platform with multi-engine Stockfish, full game review, and live analysis.",
  "scripts": {
    "predev": "node scripts/copyStockfish.mjs",
    "dev": "concurrently -n api,web -c blue,green \"npm run api:dev\" \"npm run web:dev\"",
    "dev:all": "npm run dev",
    "web:dev": "vite",
    "prebuild": "node scripts/copyStockfish.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "api:dev": "tsx scripts/apiDev.ts",
    "seed:openings": "tsx scripts/seedOpenings.ts",
    "seed:master": "tsx scripts/seedMasterGames.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/node": "^3.2.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "chess.js": "^1.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "framer-motion": "^11.3.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.408.0",
    "mongoose": "^8.5.0",
    "node-fetch": "^3.3.2",
    "pgn-parser": "^2.2.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.2",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.24.1",
    "stockfish": "^18.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vercel": "^37.0.0",
    "vite": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
