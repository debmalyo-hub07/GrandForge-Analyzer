# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
build/
.vercel/

# Environment
.env
.env.local
.env.*.local

# Stockfish WASM — the sf18 builds are copied from node_modules at build time
# (prebuild → scripts/copyStockfish.mjs), so they are ignored here, including the
# ~113 MB stockfish-18-single.wasm that exceeds GitHub's 100 MB per-file limit.
# The real sf16 / sf17.1 binaries + the sf16 NNUE network are NOT shipped by npm
# and must be committed (see the REQUIRED_REAL guard in copyStockfish.mjs).
public/stockfish/stockfish-18-*

