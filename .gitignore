.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings
.claude/settings.local.json
.claude/skills/

# Tests (kept locally, not in repo)
tests/
playwright.config.ts
src/**/__tests__/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

