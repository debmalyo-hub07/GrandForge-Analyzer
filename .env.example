# GrandForge — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# ───────── Required (development + production) ─────────
MONGODB_URI=
JWT_SECRET=
FRONTEND_URL=
NODE_ENV=

# Optional (dev only): port for the local Express API shim (scripts/apiDev.ts).
# Defaults to 3000; the Vite dev proxy targets this port.
API_PORT=3000

# ───────── Production-only ─────────
# Set FRONTEND_URL to your Vercel production domain in prod, e.g.
# FRONTEND_URL=https://your-domain.vercel.app

# Optional: higher rate limits when importing from Lichess
LICHESS_API_TOKEN=

# Required by Chess.com API politeness policy
CHESS_COM_USER_AGENT=

# Optional: serverless KV cache for rate limits (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Protects POST /api/engine-index/migrate
ADMIN_KEY=
